{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://smartpyme.local/schemas/agent-handoff-v2.0.0.json",
  "title": "AgentHandoff v2.0.0",
  "description": "Contrato canónico de transferencia entre agentes de SmartPyme Factory / SME OS",
  "type": "object",
  "required": [
    "schema_version",
    "task_id",
    "cliente_id",
    "source_agent",
    "target_agent",
    "payload_ref",
    "evidence_path",
    "created_at"
  ],
  "properties": {
    "schema_version": {"type": "string", "enum": ["2.0.0"]},
    "task_id": {"type": "string", "pattern": "^TASK-[0-9]{4}-[0-9]{2}-[0-9]{2}-[0-9]{3}$"},
    "cliente_id": {"type": "string", "minLength": 1},
    "source_agent": {"type": "string", "enum": ["hermes_gateway", "codex_builder", "gemini_auditor", "gpt_director", "human_owner"]},
    "target_agent": {"type": "string", "enum": ["hermes_gateway", "codex_builder", "gemini_auditor", "gpt_director", "human_owner"]},
    "payload_ref": {"type": "string", "minLength": 1},
    "evidence_path": {"type": "string", "pattern": "^factory/evidence/[a-zA-Z0-9_./-]+$"},
    "context_files": {"type": "array", "items": {"type": "string"}},
    "allowed_files": {"type": "array", "items": {"type": "string"}},
    "forbidden_files": {"type": "array", "items": {"type": "string"}},
    "created_at": {"type": "string", "format": "date-time"}
  },
  "additionalProperties": false
}
