{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://smartpyme.local/schemas/task-result-v2.0.0.json",
  "title": "TaskResult v2.0.0",
  "description": "Resultado de ejecución de un agente en SmartPyme Factory",
  "type": "object",
  "required": [
    "schema_version",
    "task_id",
    "cliente_id",
    "agent_id",
    "verdict",
    "evidence_path",
    "output_summary",
    "created_at"
  ],
  "properties": {
    "schema_version": {"type": "string", "enum": ["2.0.0"]},
    "task_id": {"type": "string"},
    "cliente_id": {"type": "string"},
    "agent_id": {"type": "string"},
    "verdict": {
      "type": "string",
      "enum": [
        "SUCCESS_CODE",
        "SUCCESS_FACTORY",
        "VALIDATED_ARCH",
        "BLOCKED_MISSING_ASSET",
        "BLOCKED_AMBIGUOUS_SPEC",
        "BLOCKED_IDENTIDAD_CONFLICT",
        "REJECTED_STACK",
        "REJECTED_INFERENCE",
        "REJECTED_SECURITY",
        "FAILED_LINT",
        "FAILED_RUNTIME"
      ]
    },
    "evidence_path": {"type": "string"},
    "output_summary": {"type": "string", "minLength": 5},
    "files_changed": {"type": "array", "items": {"type": "string"}},
    "tests_result": {"type": "string"},
    "blockers": {"type": "array", "items": {"type": "string"}},
    "created_at": {"type": "string", "format": "date-time"}
  },
  "additionalProperties": false
}
