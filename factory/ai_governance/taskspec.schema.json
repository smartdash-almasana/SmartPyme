{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SmartPyme Factory TaskSpec",
  "type": "object",
  "required": [
    "task_id",
    "objective",
    "allowed_files",
    "forbidden_files",
    "required_tests",
    "acceptance_criteria",
    "preflight_commands",
    "post_commands",
    "status",
    "mode",
    "operational_mode",
    "layer",
    "phase",
    "model_target"
  ],
  "properties": {
    "task_id": {
      "type": "string",
      "minLength": 3
    },
    "mode": {
      "type": "string",
      "enum": [
        "create_only",
        "patch_only",
        "governance",
        "product"
      ]
    },
    "operational_mode": {
      "type": "string",
      "enum": [
        "ANALYSIS_ONLY",
        "WRITE_AUTHORIZED",
        "TEST_ONLY",
        "CLOSE_ONLY",
        "DOC_ONLY",
        "BLOCKED_REVIEW"
      ]
    },
    "layer": {
      "type": "string",
      "minLength": 1
    },
    "phase": {
      "type": "string",
      "enum": [
        "DEFINIR",
        "CONTRATAR",
        "IMPLEMENTAR",
        "INTEGRAR",
        "AUDITAR",
        "CERRAR",
        "DOCUMENTAR"
      ]
    },
    "model_target": {
      "type": "string",
      "enum": [
        "CODEX",
        "DEEPSEEK_4_PRO",
        "DEEPSEEK_3_2"
      ]
    },
    "max_files_read": {
      "type": "integer",
      "minimum": 1,
      "maximum": 20
    },
    "max_searches": {
      "type": "integer",
      "minimum": 0,
      "maximum": 10
    },
    "objective": {
      "type": "string",
      "minLength": 10
    },
    "allowed_files": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "forbidden_files": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "locked_files": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "required_tests": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "acceptance_criteria": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "preflight_commands": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "post_commands": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "status": {
      "type": "string",
      "enum": [
        "pending",
        "in_progress",
        "submitted",
        "blocked",
        "validated",
        "rejected"
      ]
    },
    "human_required": {
      "type": "boolean"
    }
  },
  "additionalProperties": false
}