{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SmartPyme Factory TaskSpec",
  "type": "object",
  "required": [
    "task_id",
    "objective",
    "allowed_files",
    "forbidden_files",
    "required_tests",
    "acceptance_criteria",
    "preflight_commands",
    "post_commands",
    "status",
    "mode"
  ],
  "properties": {
    "task_id": {
      "type": "string",
      "minLength": 3
    },
    "mode": {
      "type": "string",
      "enum": [
        "create_only",
        "patch_only",
        "governance",
        "product"
      ]
    },
    "objective": {
      "type": "string",
      "minLength": 10
    },
    "allowed_files": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "forbidden_files": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "locked_files": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "required_tests": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "acceptance_criteria": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "preflight_commands": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "post_commands": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "status": {
      "type": "string",
      "enum": [
        "pending",
        "in_progress",
        "submitted",
        "blocked",
        "validated",
        "rejected"
      ]
    },
    "human_required": {
      "type": "boolean"
    }
  },
  "additionalProperties": false
}