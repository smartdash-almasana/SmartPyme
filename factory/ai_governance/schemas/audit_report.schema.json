{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AuditReport v1",
  "type": "object",
  "required": ["task_id", "agent_id", "timestamp", "verdict", "evidence_path", "summary"],
  "properties": {
    "task_id": {"type": "string"},
    "agent_id": {"type": "string", "enum": ["factory_auditor", "gpt_director"]},
    "timestamp": {"type": "string", "format": "date-time"},
    "verdict": {"type": "string", "enum": ["AUDIT_PASSED", "AUDIT_REJECTED", "AUDIT_BLOCKED", "AUDIT_INCOMPLETE", "APPROVED", "REJECTED", "BLOCKED", "NEEDS_REVIEW"]},
    "summary": {"type": "string"},
    "evidence_path": {"type": "string"},
    "issues": {"type": "array", "items": {"type": "string"}},
    "required_followup": {"type": "array", "items": {"type": "string"}}
  },
  "additionalProperties": false
}
