{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SmartPyme Factory State Machine",
  "type": "object",
  "required": ["version", "states", "transitions"],
  "properties": {
    "version": {"type": "string"},
    "states": {"type": "array", "items": {"type": "string"}},
    "transitions": {"type": "array", "items": {"type": "object", "required": ["from", "to", "event"], "properties": {"from": {"type": "string"}, "to": {"type": "string"}, "event": {"type": "string"}}}}
  }
}
